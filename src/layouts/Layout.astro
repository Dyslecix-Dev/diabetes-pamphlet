---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Diabetes Pamphlet", description = "A scrollytelling exploration of diabetes: what it is, how it develops, and what you can do about it." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts: DM Serif Display, DM Sans, JetBrains Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Serif+Display&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
  </head>
  <body class="antialiased">
    <!-- Min-width warning for screens < 1024px -->
    <div id="screen-warning" class="fixed inset-0 z-9999 flex items-center justify-center bg-bg p-8 text-center lg:hidden">
      <div>
        <p class="font-display text-2xl" style="color: var(--color-green-dark);">This experience is designed for larger screens.</p>
        <p class="mt-3 text-lg" style="color: var(--color-text-muted);">Please view on a device at least <strong>1024px</strong> wide for the best experience.</p>
      </div>
    </div>

    <!-- Ambient floating orbs -->
    <div class="ambient-orbs hidden lg:block" aria-hidden="true">
      <div class="orb-3"></div>
      <div class="orb-4"></div>
    </div>

    <div class="hidden lg:contents">
      <a
        href="#main-content"
        class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-100 focus:rounded focus:bg-green-dark focus:px-4 focus:py-2 focus:text-white focus:outline-none"
      >
        Skip to main content
      </a>
      <slot />
    </div>
  </body>
</html>
