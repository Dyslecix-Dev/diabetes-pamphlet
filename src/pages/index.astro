---
import Layout from "../layouts/Layout.astro";
import ProgressBar from "../components/ProgressBar";
import ChapterNav from "../components/ChapterNav";
import ScrollyDemo from "../components/ScrollyDemo";
---

<Layout>
  <ProgressBar client:load />
  <ChapterNav client:load />

  <main>
    <!-- Phase 3 demo: scrollytelling wrapper test -->
    <ScrollyDemo client:load />

    <section id="section-1" class="min-h-screen flex items-center justify-center">
      <p class="text-text-muted font-body">Section 1: What Is Diabetes? — coming soon</p>
    </section>
    <section id="section-2" class="min-h-screen flex items-center justify-center bg-bg-section">
      <p class="text-text-muted font-body">Section 2: Type I vs. Type II — coming soon</p>
    </section>
    <section id="section-3" class="min-h-screen flex items-center justify-center">
      <p class="text-text-muted font-body">Section 3: How It Develops — coming soon</p>
    </section>
    <section id="section-4" class="min-h-screen flex items-center justify-center bg-bg-section">
      <p class="text-text-muted font-body">Section 4: Treatments — coming soon</p>
    </section>
    <section id="section-5" class="min-h-screen flex items-center justify-center">
      <p class="text-text-muted font-body">Section 5: Risks & Prevention — coming soon</p>
    </section>
    <section id="section-6" class="min-h-screen flex items-center justify-center bg-bg-section">
      <p class="text-text-muted font-body">Section 6: Living with Diabetes — coming soon</p>
    </section>
  </main>
</Layout>
