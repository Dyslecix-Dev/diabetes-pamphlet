    <script is:inline>
      // Desktop popup — only show on viewports >= 1024px
      (function () {
        var popup = document.getElementById("desktop-popup");
        var dismiss = document.getElementById("desktop-popup-dismiss");
        if (!popup || !dismiss) return;

        var dismissed = false;

        function showIfDesktop() {
          if (dismissed) return;
          if (window.innerWidth >= 1024) {
            popup.classList.add("show");
          }
        }

        function close() {
          dismissed = true;
          popup.classList.remove("show");
        }

        dismiss.addEventListener("click", close);

        popup.addEventListener("click", function (e) {
          if (e.target === popup) close();
        });

        setTimeout(showIfDesktop, 1500);
      })();

      // Intersection Observer for entrance animations
      const sections = document.querySelectorAll("[data-section]");
      const entranceObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target;
              el.classList.add("visible");
              setTimeout(() => {
                el.querySelectorAll(".bar-fill[data-width]").forEach(function (bar) {
                  bar.style.width = bar.getAttribute("data-width") || "";
                });
              }, 300);
              setTimeout(() => {
                el.classList.add("idle");
              }, 1200);
              entranceObserver.unobserve(el);
            }
          });
        },
        { threshold: 0.15 },
      );
      sections.forEach((s) => entranceObserver.observe(s));
    </script>
